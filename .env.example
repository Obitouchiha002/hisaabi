# AI dimaag ke liye — in me se koi EK bhi kaafi hai.
# Ye keys SERVER pe rehti hain (Vercel → Settings → Environment Variables).
# App ke bundle me kabhi mat daalna (VITE_ prefix mat lagana) — warna DevTools
# kholke koi bhi utha lega aur bill tumhara aayega.

# Pehli pasand — sabse tez aur sasta
GROQ_API_KEY=

# Fallback
GEMINI_API_KEY=

# Dono khaali chhod do to /api/ai 503 dega aur app chup-chaap rule parser pe
# chalti rahegi. Kuch tootega nahi — bas "chai bees" jaisi saaf lines hi banengi.
